runtime: php82
env: standard
instance_class: F1

automatic_scaling:
  max_instances: 2
  min_instances: 0

env_variables:
  # Database Config
  DB_SOCKET: "/cloudsql/YOUR_PROJECT:YOUR_REGION:YOUR_INSTANCE"
  DB_NAME: "YOUR_DB_NAME"
  DB_USER: "YOUR_DB_USER"
  DB_PASS: "YOUR_DB_PASSWORD"

  # Storage and API Config
  STORAGE_BUCKET: "YOUR_STORAGE_BUCKET"
  MAPS_API_KEY: "YOUR_MAPS_API_KEY"

  # App Environment
  APP_ENV: "production"
  APP_DEBUG: "false"
