# Database Configuration
DB_HOST=localhost
DB_NAME=barangay_reports
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Email Configuration - Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=your-email@example.com
MAILGUN_FROM_NAME=CommuniLink Barangay System

# Email Configuration - Gmail SMTP
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USERNAME=your-email@gmail.com
EMAIL_SMTP_PASSWORD=your-app-password-here
EMAIL_SMTP_SECURE=ssl
EMAIL_FROM_EMAIL=your-email@gmail.com
EMAIL_FROM_NAME=CommuniLink Barangay System

# Application Configuration
APP_ENV=development
APP_DEBUG=false
APP_URL=http://localhost/barangay

# Session and Concurrency Configuration
SESSION_LIFETIME=300
ADMIN_SESSION_LIFETIME=1800
ENABLE_CONCURRENCY_CAPS=true
ADMIN_MAX_CONCURRENT=2
OFFICIAL_MAX_CONCURRENT=5
AUTO_KICK_DUPLICATE_SESSIONS=false
BULK_IDLE_MINUTES_DEFAULT=15
POLLING_INTERVAL_MS=15000
ADMIN_MAX_USERS=5

# CSP rollout controls (Phase 3B no-downtime hardening)
CSP_REPORT_ONLY=true
CSP_REPORT_URI=/api/csp-report.php
CSP_REPORT_ENDPOINT_ENABLED=true

# Initial admin bootstrap password (required for first-run seeding when no admin account exists)
ADMIN_INITIAL_PASSWORD=

# Duplicate auto-kick applies to admin/official roles only.
# Polling interval: How often the active sessions dashboard refreshes (in milliseconds). Default: 15000 (15 seconds)
